import { VerticalBox, HorizontalBox, TabWidget, Button, LineEdit, GroupBox, ComboBox, Slider } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "PyGrove Wallet";
    preferred-width: 960px;
    preferred-height: 640px;
    background: #0b0d10;

    // Wallet
    in-out property <string> wallet_address: "—";
    in-out property <string> wallet_pubkey: "—";
    in-out property <string> balance_sat: "0";
    in-out property <string> wallet_nonce: "0";
    in-out property <string> send_to: "";
    in-out property <string> send_amount: "";
    in-out property <string> send_fee: "100";
    in-out property <string> send_status: "";
    in-out property <string> block_height: "0";
    in-out property <string> regime: "equilibrium";
    in-out property <string> halving_progress: "0 / 210000";
    in-out property <string> reward_sat: "5000000000";

    // Mining
    in-out property <string> rpc_url: "http://66.42.93.85:8545";
    in-out property <string> mine_status: "idle";
    in-out property <string> hashrate: "0 H/s";
    in-out property <string> accepted: "0";
    in-out property <string> rejected: "0";
    in-out property <string> current_target: "—";
    in-out property <string> node_tip_hash: "—";
    in-out property <string> node_chain_id: "—";
    in-out property <bool>   mining_on: false;
    in-out property <[string]> device_model: ["CPU", "GPU (coming in v0.2)"];
    in-out property <int>    device_index: 0;
    in-out property <float>  intensity: 4.0;      // CPU threads; capped to cores at runtime
    in-out property <int>    cpu_cores: 1;

    callback connect_clicked();
    callback mine_toggle();
    callback send_clicked();
    callback copy_address();
    callback regenerate_wallet();

    VerticalBox {
        padding: 16px;
        spacing: 12px;

        Text {
            text: "PyGrove Chain";
            font-size: 22px;
            color: #e8f0ff;
        }

        TabWidget {
            Tab {
                title: "Wallet";
                VerticalBox {
                    padding: 12px;
                    spacing: 8px;
                    GroupBox {
                        title: "Your address";
                        VerticalBox {
                            spacing: 6px;
                            // Read-only LineEdit so the address is selectable
                            // (Ctrl+A / Ctrl+C) — Slint's plain Text widget is not.
                            LineEdit {
                                text: root.wallet_address;
                                read-only: true;
                            }
                            HorizontalBox {
                                Button {
                                    text: "Copy";
                                    clicked => { root.copy_address(); }
                                }
                                Button {
                                    text: "Regenerate (destroys old wallet)";
                                    clicked => { root.regenerate_wallet(); }
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }
                            Text {
                                text: "Share this address to receive PYG. Mining rewards land here too.";
                                color: #9aa6b2;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                        }
                    }
                    GroupBox {
                        title: "Balance";
                        VerticalBox {
                            Text { text: root.balance_sat + " sat"; color: #e8f0ff; font-size: 16px; }
                            Text { text: "nonce: " + root.wallet_nonce; color: #9aa6b2; font-size: 11px; }
                        }
                    }
                    GroupBox {
                        title: "Send";
                        VerticalBox {
                            spacing: 6px;
                            HorizontalBox {
                                Text { text: "to:"; color: #e8f0ff; width: 70px; }
                                LineEdit {
                                    text: root.send_to;
                                    placeholder-text: "pyg1...";
                                    edited => { root.send_to = self.text; }
                                }
                            }
                            HorizontalBox {
                                Text { text: "amount:"; color: #e8f0ff; width: 70px; }
                                LineEdit {
                                    text: root.send_amount;
                                    placeholder-text: "sat";
                                    edited => { root.send_amount = self.text; }
                                }
                            }
                            HorizontalBox {
                                Text { text: "fee:"; color: #e8f0ff; width: 70px; }
                                LineEdit {
                                    text: root.send_fee;
                                    placeholder-text: "sat";
                                    edited => { root.send_fee = self.text; }
                                }
                            }
                            Button {
                                text: "Sign + submit";
                                clicked => { root.send_clicked(); }
                            }
                            Text { text: root.send_status; color: #c0ccd8; font-size: 11px; wrap: word-wrap; }
                        }
                    }
                }
            }
            Tab {
                title: "Mining";
                VerticalBox {
                    padding: 12px;
                    spacing: 10px;
                    GroupBox {
                        title: "Node";
                        VerticalBox {
                            HorizontalBox {
                                Text { text: "RPC URL:"; color: #e8f0ff; }
                                LineEdit {
                                    text: root.rpc_url;
                                    placeholder-text: "http://host:8545";
                                    edited => { root.rpc_url = self.text; }
                                }
                                Button {
                                    text: "Connect";
                                    clicked => { root.connect_clicked(); }
                                }
                            }
                            Text { text: "chain_id: " + root.node_chain_id; color: #c0ccd8; }
                            Text { text: "tip:      " + root.node_tip_hash; color: #c0ccd8; }
                        }
                    }
                    GroupBox {
                        title: "Miner";
                        VerticalBox {
                            spacing: 6px;
                            HorizontalBox {
                                Text { text: "Device:"; color: #e8f0ff; width: 80px; }
                                ComboBox {
                                    model: root.device_model;
                                    current-index: root.device_index;
                                    selected(v) => { root.device_index = self.current-index; }
                                }
                            }
                            HorizontalBox {
                                Text { text: "Intensity:"; color: #e8f0ff; width: 80px; }
                                Slider {
                                    minimum: 1;
                                    maximum: root.cpu_cores > 1 ? root.cpu_cores : 16;
                                    value: root.intensity;
                                    changed(v) => { root.intensity = self.value; }
                                }
                                Text {
                                    text: Math.round(root.intensity) + " thread" + (Math.round(root.intensity) == 1 ? "" : "s");
                                    color: #c0ccd8;
                                    width: 110px;
                                }
                            }
                            Text {
                                text: "detected cores: " + root.cpu_cores;
                                color: #9aa6b2;
                                font-size: 11px;
                            }
                            Text { text: "status:   " + root.mine_status; color: #e8f0ff; }
                            Text { text: "hashrate: " + root.hashrate; color: #e8f0ff; }
                            Text { text: "accepted: " + root.accepted + "    rejected: " + root.rejected; color: #c0ccd8; }
                            Text { text: "target:   " + root.current_target; color: #9aa6b2; }
                            Button {
                                text: root.mining_on ? "Stop mining" : "Start mining";
                                clicked => { root.mine_toggle(); }
                            }
                        }
                    }
                }
            }
            Tab {
                title: "Reflection";
                VerticalBox {
                    padding: 12px;
                    Text {
                        text: "short (144) / long (2016) / epoch (210000) windows will render here once the node RPC is wired.";
                        color: #c0ccd8;
                        wrap: word-wrap;
                    }
                }
            }
            Tab {
                title: "Governance";
                VerticalBox {
                    padding: 12px;
                    Text {
                        text: "UpgradeCrypto proposals and cold-key signing.";
                        color: #c0ccd8;
                    }
                }
            }
        }

        HorizontalBox {
            Text { text: "height: " + root.block_height; color: #9aa6b2; }
            Rectangle { horizontal-stretch: 1; }
            Text { text: "v0.1.0"; color: #9aa6b2; }
        }
    }
}
